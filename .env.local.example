# Public site URL (used in emails for confirmation/unsubscribe links)
NEXT_PUBLIC_SITE_URL=https://justgetfit.org

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (for AI draft generation)
ANTHROPIC_API_KEY=sk-ant-your-key

# Unsplash (for cover photos - free at unsplash.com/developers)
UNSPLASH_ACCESS_KEY=your-unsplash-access-key

# Resend (for contact form + newsletter - free at resend.com)
RESEND_API_KEY=re_your-key
RESEND_FROM_EMAIL="Just Get Fit <hello@justgetfit.org>"
CONTACT_EMAIL=hello@justgetfit.org

# Cron security (any random string)
CRON_SECRET=generate-random-string

# Admin password
ADMIN_PASSWORD=set-a-strong-password
